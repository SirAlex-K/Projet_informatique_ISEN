# Prisma attend une URL complète (pas des variables séparées)
# Pour PostgreSQL (utilisé dans ce projet) :
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Exemple local : postgresql://postgres:motdepasse@localhost:5432/plateforme_projets

# Pour MySQL/WAMP si vous avez changé le provider dans schema.prisma :
# DATABASE_URL="mysql://root:@localhost:3306/plateforme_projets"

JWT_SECRET=votre_secret_jwt_ici_changez_moi
PORT=5000
