// ============================================
// Prisma Schema — Plateforme Projets ISEN 2026
// BDD : PostgreSQL  |  ORM : Prisma
// Conforme au Cahier des Charges v2
// 12 modèles
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUM : rôles utilisateurs (CDC §2 — 4 rôles)
// ============================================
enum UserRole {
  student       // Étudiant
  team_leader   // Chef de projet (Team Leader)
  supervisor    // Encadrant
  jury          // Jury de soutenance
}

// ============================================
// ENUM : statuts de projet (CDC §3 — 7 états)
// ============================================
enum ProjectStatut {
  propose    // Proposé
  valide     // Validé
  en_cours   // En cours
  en_retard  // En retard
  livre      // Livré
  soutenu    // Soutenu
  cloture    // Clôturé
}

// ============================================
// ENUM : statuts de tâche (CDC §4 — 3 états)
// ============================================
enum TaskStatut {
  todo      // À faire
  en_cours  // En cours
  done      // Terminé
}

// ============================================
// ENUM : priorité des tâches
// ============================================
enum Priorite {
  basse
  normale
  haute
}

// ============================================
// ENUM : rôle dans l'équipe
// ============================================
enum RoleInProject {
  member
  lead
}

// ============================================
// ENUM : types de notification (CDC §5)
// ============================================
enum NotificationType {
  task_assigned       // Tâche assignée
  task_updated        // Tâche mise à jour
  deliverable_uploaded // Livrable déposé
  deliverable_reviewed // Livrable évalué
  comment_added       // Nouveau commentaire
  milestone_reached   // Jalon atteint
  project_updated     // Projet mis à jour
}

// ============================================
// ENUM : décision sur un livrable (CDC §6)
// ============================================
enum DeliverableDecision {
  accepte   // Accepté
  rejete    // Rejeté
  revision  // À réviser
}


// ============================================
// MODEL : users
// Table centrale — 4 rôles (CDC §2)
// ============================================
model User {
  id            Int       @id @default(autoincrement())
  nom           String    @db.VarChar(100)
  prenom        String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password_hash String
  role          UserRole  @default(student)
  avatar_url    String?
  created_at    DateTime  @default(now())

  // Relations
  projects_supervised  Project[]          @relation("SupervisorProjects")
  team_memberships     TeamMember[]
  tasks_assigned       Task[]             @relation("AssignedTasks")
  deliverables         Deliverable[]
  messages_sent        Message[]
  task_history         TaskHistory[]
  comments             Comment[]
  notifications        Notification[]
  deliverable_reviews  DeliverableReview[]
  evaluations_given    Evaluation[]       @relation("EvaluatorEvaluations")

  @@map("users")
}


// ============================================
// MODEL : projects
// Lié à un encadrant — 7 statuts (CDC §3)
// ============================================
model Project {
  id            Int            @id @default(autoincrement())
  titre         String         @db.VarChar(200)
  description   String?
  supervisor_id Int
  date_debut    DateTime?      @db.Date
  date_fin      DateTime?      @db.Date
  statut        ProjectStatut  @default(propose)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  // Relations
  supervisor          User               @relation("SupervisorProjects", fields: [supervisor_id], references: [id], onDelete: Cascade)
  members             TeamMember[]
  tasks               Task[]
  deliverables        Deliverable[]
  messages            Message[]
  milestones          Milestone[]
  comments            Comment[]
  notifications       Notification[]
  evaluations         Evaluation[]

  @@map("projects")
}


// ============================================
// MODEL : team_members
// Table pivot N:N — un étudiant peut être
// dans plusieurs projets, avec un rôle
// ============================================
model TeamMember {
  project_id      Int
  user_id         Int
  role_in_project RoleInProject @default(member)
  joined_at       DateTime      @default(now())

  // Relations
  project         Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Un user ne peut être qu'une fois dans un projet
  @@id([project_id, user_id])
  @@map("team_members")
}


// ============================================
// MODEL : tasks
// Suivi des tâches — vue Kanban en bonus
// 3 statuts CDC : todo / en_cours / done
// ============================================
model Task {
  id          Int         @id @default(autoincrement())
  project_id  Int
  assigned_to Int?
  titre       String      @db.VarChar(200)
  description String?
  statut      TaskStatut  @default(todo)
  priorite    Priorite    @default(normale)
  deadline    DateTime?   @db.Date
  position    Int         @default(0)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  // Relations
  project     Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee    User?       @relation("AssignedTasks", fields: [assigned_to], references: [id], onDelete: SetNull)
  history     TaskHistory[]
  comments    Comment[]

  @@map("tasks")
}


// ============================================
// MODEL : deliverables
// Dépôt de fichiers (Multer) — max 10MB
// Formats : PDF, ZIP, DOCX, PNG, JPG
// ============================================
model Deliverable {
  id             Int      @id @default(autoincrement())
  project_id     Int
  uploaded_by    Int
  nom_fichier    String   @db.VarChar(255)
  chemin_fichier String
  type_fichier   String   @db.VarChar(50)
  taille         Int
  uploaded_at    DateTime @default(now())

  // Relations
  project        Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  uploader       User              @relation(fields: [uploaded_by], references: [id], onDelete: Cascade)
  reviews        DeliverableReview[]

  @@map("deliverables")
}


// ============================================
// MODEL : messages
// Chat par projet — un canal par projet
// ============================================
model Message {
  id         Int      @id @default(autoincrement())
  project_id Int
  sender_id  Int
  contenu    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  // Relations
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@map("messages")
}


// ============================================
// MODEL : task_history
// Historique des changements de statut des tâches
// ============================================
model TaskHistory {
  id             Int        @id @default(autoincrement())
  task_id        Int
  changed_by     Int
  ancien_statut  TaskStatut
  nouveau_statut TaskStatut
  changed_at     DateTime   @default(now())

  // Relations
  task           Task       @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [changed_by], references: [id], onDelete: Cascade)

  @@map("task_history")
}


// ============================================
// MODEL : comments
// Commentaires sur tâches ou projets (CDC §5)
// ============================================
model Comment {
  id         Int      @id @default(autoincrement())
  project_id Int
  task_id    Int?
  author_id  Int
  contenu    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [task_id], references: [id], onDelete: SetNull)
  author     User     @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("comments")
}


// ============================================
// MODEL : milestones
// Jalons du projet (CDC §4)
// ============================================
model Milestone {
  id          Int      @id @default(autoincrement())
  project_id  Int
  titre       String   @db.VarChar(200)
  description String?
  date_cible  DateTime @db.Date
  atteint     Boolean  @default(false)
  atteint_le  DateTime?
  created_at  DateTime @default(now())

  // Relations
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("milestones")
}


// ============================================
// MODEL : notifications
// Alertes système automatiques (CDC §5)
// ============================================
model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  project_id Int?
  type       NotificationType
  contenu    String
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  // Relations
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project    Project?         @relation(fields: [project_id], references: [id], onDelete: SetNull)

  @@map("notifications")
}


// ============================================
// MODEL : deliverable_reviews
// Validation des livrables par encadrant (CDC §6)
// ============================================
model DeliverableReview {
  id             Int                 @id @default(autoincrement())
  deliverable_id Int
  reviewer_id    Int
  decision       DeliverableDecision
  commentaire    String?
  reviewed_at    DateTime            @default(now())

  // Relations
  deliverable    Deliverable         @relation(fields: [deliverable_id], references: [id], onDelete: Cascade)
  reviewer       User                @relation(fields: [reviewer_id], references: [id], onDelete: Cascade)

  @@map("deliverable_reviews")
}


// ============================================
// MODEL : evaluations
// Notes de soutenance par le jury (CDC §7)
// ============================================
model Evaluation {
  id           Int      @id @default(autoincrement())
  project_id   Int
  evaluator_id Int
  note         Float
  commentaire  String?
  evaluated_at DateTime @default(now())

  // Relations
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  evaluator    User     @relation("EvaluatorEvaluations", fields: [evaluator_id], references: [id], onDelete: Cascade)

  @@map("evaluations")
}
